# ─── Frontend (browser-visible) ────────────────────────────────────────────────
# Optional override. When unset, the app uses a relative /api path which
# works automatically on Vercel (same origin) and in local dev (Vite proxy).
# Only set this if your API is hosted on a different domain.
VITE_API_BASE_URL=

# ─── Backend (Vercel Serverless / local dev) ───────────────────────────────────
# These never reach the browser. Set them in Vercel project settings (and in
# this .env locally for `npm run dev:api`).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

JWT_SECRET=replace_me_with_a_long_random_string

# TheSportsDB v1 API key. Leave blank to use the public free key "123"
# (30 req/min, no signup). Register for a free private key, or pay $9/mo
# for premium V2 (livescores + larger limits).
SPORTSDB_API_KEY=

# Optional — Resend for approval emails. Leave RESEND_API_KEY blank to skip.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional — only set in production to lock CORS to your Vercel URL.
CLIENT_ORIGIN=
