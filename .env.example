# ─── Frontend (browser-visible) ────────────────────────────────────────────────
# Optional override. When unset, the app uses a relative /api path which
# works automatically on Vercel (same origin) and in local dev (Vite proxy).
# Only set this if your API is hosted on a different domain.
VITE_API_BASE_URL=

# Optional — simulation / demo mode (local testing only).
# Must be exactly "true" to activate. OFF by default.
# Serves in-memory demo data; no Supabase writes. Do NOT set in production.
VITE_SIMULATION_MODE=

# ─── Backend (Vercel Serverless / local dev) ───────────────────────────────────
# These never reach the browser. Set them in Vercel project settings (and in
# this .env locally for `npm run dev:api`).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

JWT_SECRET=replace_me_with_a_long_random_string

# worldcup26.ir football data (https://worldcup26.ir/api-docs/).
# Auth is optional for read endpoints today; set credentials if upstream
# starts requiring JWT on /get/games and /get/teams.
WC26_API_BASE_URL=https://worldcup26.ir
WC26_API_EMAIL=
WC26_API_PASSWORD=

# Optional — Resend for approval emails. Leave RESEND_API_KEY blank to skip.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional — only set in production to lock CORS to your Vercel URL.
CLIENT_ORIGIN=

# ─── Supabase matches mirror (Phase 2) ────────────────────────────────────────
# When true, user-facing routes read matches/teams from the Supabase mirror
# (populated by the /api/cron/refresh-matches cron + admin backfill) instead
# of calling worldcup26.ir on the request path. Default OFF — without this
# flag the live-fetch behavior is unchanged.
#
# Recommended rollout: leave unset in Production until Preview verification
# (/api/admin/mirror-compare returns allMatch:true) has passed.
USE_MATCHES_MIRROR=false

# Shared secret for the Vercel Cron call into /api/cron/refresh-matches.
# Set in Vercel project env vars; the cron sends Authorization: Bearer ${CRON_SECRET}.
# If unset, the cron route still accepts a signed-in admin session as
# fallback (curl with cookie).
CRON_SECRET=
