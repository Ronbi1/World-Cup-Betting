{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-matches",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/live-scores",
      "schedule": "* * * * *"
    }
  ]
}
